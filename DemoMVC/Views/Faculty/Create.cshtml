@model Sinhvien.Models.Faculty

<h2>Thêm khoa</h2>

<form asp-action="Create" method="post">
    <div>
        <label>Mã khoa</label>
        <input asp-for="FacultyId" />
        <span asp-validation-for="FacultyId"></span>
    </div>

    <div>
        <label>Tên khoa</label>
        <input asp-for="FacultyName" />
        <span asp-validation-for="FacultyName"></span>
    </div>

    <button type="submit">Thêm</button>
</form>

<a asp-action="Index">Quay lại</a>