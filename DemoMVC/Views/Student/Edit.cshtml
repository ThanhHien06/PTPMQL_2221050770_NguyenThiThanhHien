@model DemoMVC.Models.Entities.Student
<h2>Form sửa dữ liệu sinh viên</h2>
<form asp-action="Edit" method="post">
    <input type="hidden" name="id" value="@Model.StudentCode" />
    <div class="form-group">
        <label>Mã sinh viên</label>
        <input type="text" class="form-control" name="StudentCode" placeholder="Nhập mã sinh viên" value="@Model.StudentCode">
    </div>
    <div class="form-group">
        <label>Tên sinh viên</label>
        <input type="text" class="form-control" name="FullName" placeholder="Nhập Tên sinh viên" value="@Model.FullName">
    </div>
    <div class="form-group">
        <label>Tuổi</label>
        <input type="text" class="form-control" name="Age" placeholder="Nhập tuổi" value="@Model.Age">
    </div>
    <div class="form-group">
        <label>Email</label>
        <input type="text" class="form-control" name="Email" placeholder="Nhập email" value="@Model.Email">
    </div>
    
    <div class="form-group">
        <label>Khoa</label>
        <input type="text" class="form-control" name="FacultyName" placeholder="Nhập khoa" value="@Model.FacultyName">
    </div>
    <div class="form-group">
        <input type="submit" class="form-control" value="Update Student">
    </div>
</form>