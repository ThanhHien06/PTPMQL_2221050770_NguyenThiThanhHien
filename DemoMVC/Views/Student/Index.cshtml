@model List<StudentFacultyViewModel>
<h2>Danh sách sinh viên</h2>
<table class="table">
    <thead>
        <tr>
            <th>Student Code</th>
            <th>Full Name</th>
            <th>Faculty</th>
            @*<th>Email</th>*@
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var student in Model)
        {
            <tr>
                <td>@student.StudentCode</td>
                <td>@student.FullName</td>
                <td>@student.FacultyName</td>
                @*<td>@student.Email</td>*@
                <td>
                    <a asp-action="Edit" asp-route-id="@student.StudentCode">Edit</a>
                    <a asp-action="Delete" asp-route-id="@student.StudentCode">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>