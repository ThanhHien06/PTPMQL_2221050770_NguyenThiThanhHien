@model IEnumerable<DemoMVC.Models.Entities.ThietBi>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<form asp-action="Index" method="get" class="mb-3">
    <div class="form-actions no-color">
        <p>
            Tìm kiếm tên thiết bị: 
            <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" />
            <input type="submit" value="Tìm kiếm" class="btn btn-primary btn-sm" /> |
            <a asp-action="Index">Hiển thị tất cả</a>
        </p>
    </div>
</form>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.TenThietBi)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.LoaiThietBi)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.SoLuongTon)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.TenThietBi)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.LoaiThietBi.TenLoai)
            </td>
            <td>
                @if (item.SoLuongTon < 0)
                {
                    <span class="text-danger fw-bold">0</span>
                }
                else
                {
                    @Html.DisplayFor(modelItem => item.SoLuongTon)
                }
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.ThietBiId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.ThietBiId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.ThietBiId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
