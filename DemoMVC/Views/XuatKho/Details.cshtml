@model DemoMVC.Models.Entities.PhieuXuat

@{
    ViewData["Title"] = "Chi tiết phiếu xuất";
    decimal tongTienXuat = 0;
}

<h1>Chi Tiết Phiếu Xuất #@Model.PhieuXuatId</h1>
<hr />

<div class="mb-4">
    <p><strong>Mã phiếu:</strong> @Model.PhieuXuatId</p>
    <p><strong>Ngày xuất kho:</strong> @Model.NgayXuat.ToString("dd/MM/yyyy")</p>
</div>

<h4>Danh sách thiết bị đã xuất</h4>
<table class="table table-bordered">
    <thead class="table-primary">
        <tr>
            <th>Tên Thiết Bị</th>
            <th>Số Lượng</th>
            <th>Đơn Giá Xuất</th>
            <th>Thành Tiền</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.ChiTietPhieuXuats != null)
        {
            foreach (var item in Model.ChiTietPhieuXuats)
            {
                var thanhTien = item.SoLuong * item.DonGiaXuat;
                tongTienXuat += thanhTien;
                <tr>
                    <td>@item.ThietBi?.TenThietBi</td>
                    <td>@item.SoLuong</td>
                    <td>@item.DonGiaXuat.ToString("#,##0") đ</td>
                    <td>@thanhTien.ToString("#,##0") đ</td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="4" class="text-center italic">Không có chi tiết thiết bị cho phiếu này.</td>
            </tr>
        }
    </tbody>
    <tfoot>
        <tr>
            <th colspan="3" class="text-end">Tổng giá trị xuất kho:</th>
            <th class="text-danger">@tongTienXuat.ToString("#,##0") đ</th>
        </tr>
    </tfoot>
</table>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
</div>