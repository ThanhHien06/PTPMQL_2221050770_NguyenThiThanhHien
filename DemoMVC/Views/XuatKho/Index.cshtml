@model IEnumerable<DemoMVC.Models.Entities.PhieuXuat>

@{
    ViewData["Title"] = "Danh sách xuất kho";
}

<h1>Danh sách Phiếu Xuất Kho</h1>

<p>
    <a asp-action="Create" class="btn btn-warning fw-bold">Lập phiếu xuất mới</a>
</p>

<table class="table table-hover table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Mã Phiếu</th>
            <th>Ngày Xuất</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>@item.PhieuXuatId</td>
            <td>@item.NgayXuat.ToString("dd/MM/yyyy")</td>
            <td>
                <a asp-action="Details" asp-route-id="@item.PhieuXuatId" class="btn btn-info btn-sm">Xem chi tiết</a> |
                <a asp-action="Delete" asp-route-id="@item.PhieuXuatId" class="btn btn-danger btn-sm">Xóa</a>
            </td>
        </tr>
}
    </tbody>
</table>